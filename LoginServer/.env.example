# ============================================
# Projeto MCR - Configuração do Login Server
# ============================================
# INSTRUÇÕES: Copie este arquivo para .env.txt e preencha com suas credenciais

# Banco de Dados
MYSQL_DBNAME=BancoServer
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=<SuaSenhaDoMySQL>

# Log
ENV_LOG_LEVEL=debug

# Login Server
LOGIN_IP=127.0.0.1
LOGIN_HTTP_PORT=8080
LOGIN_GRPC_PORT=9090

# Rate Limiter
RATE_LIMITER_BURST=5
RATE_LIMITER_RATE=2

# Servidor de Jogo
SERVER_IP=127.0.0.1
SERVER_NAME=MCR
SERVER_PORT=7173
VOCATIONS=Engineer,Doctor,Magician,Runner,Teacher,Coder,Business Man,Writer,Youtuber
SERVER_LOCATION=BRA
